<NotasScreen>:
    name: "pantalla_notas"

    MDBoxLayout:
        orientation: 'vertical'

        MDBottomNavigation:

            MDBottomNavigationItem:
                name: "nav_notas"
                text: "Notas"
                icon: "notebook"

                MDBoxLayout:
                    orientation: 'vertical'

                    MDTopAppBar:
                        title: "Registro de Calificaciones"
                        elevation: 4
                        left_action_items: [["plus", lambda x: root.ir_a_registrar()]]
                        right_action_items: [["logout", lambda x: root.logout()]]

                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: ["8dp", "8dp", "8dp", "0dp"]

                        ScrollView:
                            MDList:
                                id: lista_notas

            MDBottomNavigationItem:
                name: "nav_estudiantes"
                text: "Estudiantes"
                icon: "account-multiple"

                MDBoxLayout:
                    orientation: 'vertical'

                    MDTopAppBar:
                        title: "Control de Estudiantes"
                        elevation: 4
                        right_action_items: [["logout", lambda x: root.logout()]]

                    StudentView:

            MDBottomNavigationItem:
                name: "nav_materias"
                text: "Materias"
                icon: "book-open-variant"

                MDBoxLayout:
                    orientation: 'vertical'

                    MDTopAppBar:
                        title: "Control de Materias"
                        elevation: 4
                        right_action_items: [["logout", lambda x: root.logout()]]

                    MateriaView:
