#Las vistas para registrar notas
<RegistrarNotaScreen>:
    name: "pantalla_registrar_nota"

    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            title: "Registrar Calificaciones"
            elevation: 4
            left_action_items: [["arrow-left", lambda x: root.regresar()]]

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: "24dp"
                spacing: "20dp"
                adaptive_height: True

                MDLabel:
                    text: "Formulario De carga multiple de notas"
                    font_style: "H6"
                    bold: True

                # Botón Desplegable para Estudiantes
                MDRaisedButton:
                    id: btn_estudiante
                    text: "Seleccionar Estudiante"
                    pos_hint: {"center_x": .5}
                    size_hint_x: 1
                    on_release: root.abrir_menu_estudiantes(self)

                # Botón Desplegable para Materias
                MDRaisedButton:
                    id: btn_materia
                    text: "Seleccionar Materia"
                    pos_hint: {"center_x": .5}
                    size_hint_x: 1
                    on_release: root.abrir_menu_materias(self)

                # 
                MDBoxLayout:
                    id: contenedor_inputs
                    orientation: 'vertical'
                    spacing: "12dp"
                    adaptive_height: True

                # ➕ BOTÓN PARA AGREGAR FILA (Python también lo necesita para ocultarlo/mostrarlo)
                MDRoundFlatIconButton:
                    id: btn_agregar_fila
                    text: "Añadir otra evaluación"
                    icon: "plus"
                    pos_hint: {"center_x": .5}
                    opacity: 0         
                    disabled: True     
                    on_release: root.agregar_fila_formulario()

                MDRaisedButton:
                    text: "Guardar Todas las Calificaciones"
                    pos_hint: {"center_x": .5}
                    size_hint_x: 0.8
                    md_bg_color: 0.7, 0.1, 0.1, 1  
                    on_release: root.guardar_todas_las_notas()